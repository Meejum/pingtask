rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users: authenticated can read (for PIN lookup), only owner writes
    match /users/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == uid;
    }

    // PINs: only Cloud Functions (admin SDK) can write, authenticated can read
    match /pins/{pin} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Contacts: only owner can read/write their contacts
    match /contacts/{uid}/list/{contactId} {
      allow read, write: if request.auth.uid == uid;
    }

    // Conversations: only participants can access
    match /conversations/{convoId} {
      allow read: if request.auth.uid in resource.data.participantUids;
      allow create: if request.auth.uid in request.resource.data.participantUids;
      allow update: if request.auth.uid in resource.data.participantUids;

      // Messages: only conversation participants
      match /messages/{messageId} {
        allow read: if request.auth.uid in
          get(/databases/$(database)/documents/conversations/$(convoId)).data.participantUids;
        allow create: if request.auth.uid in
          get(/databases/$(database)/documents/conversations/$(convoId)).data.participantUids
          && request.resource.data.senderId == request.auth.uid;
        allow update: if request.auth.uid in
          get(/databases/$(database)/documents/conversations/$(convoId)).data.participantUids;
      }
    }

    // Tasks: participants (assignee or assigner) can access
    match /tasks/{taskId} {
      allow read: if request.auth.uid in resource.data.participants;
      allow create: if request.auth.uid in request.resource.data.participants;
      allow update: if request.auth.uid in resource.data.participants;
    }
  }
}
